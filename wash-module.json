{
  "id": "washesnearby",
  "name": {
    "ru": "Автомойки рядом",
    "en": "Washes Nearby"
  },
  "description": {
    "ru": "Создаёт мойки и адрес на сайте «Автомойки рядом», синхронизирует цены (макс. по постам), занятость, новости и акции.",
    "en": "Creates washes on Washes Nearby, syncs max mode prices, post occupancy, news and promotions."
  },
  "version": "1.0.0",
  "author": "WASH-PRO",
  "license": "MIT",
  "category": "publishing",
  "icon": "assets/icon.svg",
  "repository": "https://github.com/WASH-PRO/wash-module-washesnearby",
  "dependencies": [],
  "minCrmVersion": "1.1.30",
  "entrypoint": "src/main.py",
  "helpPage": "ui/help.html",
  "scriptType": "daemon",
  "settingsSchema": [
    {
      "key": "owner_api_token",
      "type": "string",
      "label": {
        "ru": "Owner API токен",
        "en": "Owner API token"
      },
      "default": ""
    },
    {
      "key": "maps_api_base",
      "type": "string",
      "label": {
        "ru": "URL API Автомойки рядом",
        "en": "Washes Nearby API URL"
      },
      "default": "https://мойка-про.рф"
    },
    {
      "key": "default_latitude",
      "type": "number",
      "label": {
        "ru": "Широта по умолчанию",
        "en": "Default latitude"
      },
      "default": 55.1644
    },
    {
      "key": "default_longitude",
      "type": "number",
      "label": {
        "ru": "Долгота по умолчанию",
        "en": "Default longitude"
      },
      "default": 61.4368
    },
    {
      "key": "default_city",
      "type": "string",
      "label": {
        "ru": "Город по умолчанию",
        "en": "Default city"
      },
      "default": ""
    },
    {
      "key": "wash_coords",
      "type": "string",
      "label": {
        "ru": "Координаты моек (JSON)",
        "en": "Wash coordinates (JSON)"
      },
      "default": ""
    },
    {
      "key": "wash_mapping",
      "type": "string",
      "label": {
        "ru": "Сопоставление CRM→сайт (JSON)",
        "en": "CRM→site mapping (JSON)"
      },
      "default": ""
    },
    {
      "key": "wash_id",
      "type": "string",
      "label": {
        "ru": "Только мойка CRM (пусто = все)",
        "en": "Only CRM wash id (empty = all)"
      },
      "default": ""
    },
    {
      "key": "wash_type",
      "type": "string",
      "label": {
        "ru": "Тип мойки (self_service/robot/manual)",
        "en": "Wash type (self_service/robot/manual)"
      },
      "default": "self_service"
    },
    {
      "key": "poll_interval",
      "type": "number",
      "label": {
        "ru": "Интервал синхронизации (сек)",
        "en": "Sync interval (sec)"
      },
      "default": 60,
      "min": 60,
      "max": 3600
    },
    {
      "key": "news_limit",
      "type": "number",
      "label": {
        "ru": "Лимит новостей/акций",
        "en": "News/promotions limit"
      },
      "default": 5,
      "min": 1,
      "max": 50
    }
  ]
}
