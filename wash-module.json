{
  "id": "washesnearby",
  "name": {
    "ru": "Автомойки рядом",
    "en": "Washes Nearby"
  },
  "description": {
    "ru": "Создаёт мойки на сайте «Автомойки рядом» по UUID (mapsExternalId); синхронизирует цены, занятость, новости/акции и кассу (finance) в telemetry.",
    "en": "Creates washes on Washes Nearby using CRM UUID (mapsExternalId); syncs prices, occupancy, news/promos and cash register (finance) via telemetry."
  },
  "version": "1.2.3",
  "author": "WASH-PRO",
  "license": "MIT",
  "category": "publishing",
  "icon": "assets/icon.svg",
  "repository": "https://github.com/WASH-PRO/wash-module-washesnearby",
  "dependencies": [],
  "minCrmVersion": "1.1.30",
  "entrypoint": "src/main.py",
  "helpPage": "ui/help.html",
  "scriptType": "daemon",
  "settingsSchema": [
    {
      "key": "owner_api_token",
      "type": "string",
      "label": {
        "ru": "Owner API токен",
        "en": "Owner API token"
      },
      "default": ""
    },
    {
      "key": "maps_api_base",
      "type": "string",
      "label": {
        "ru": "Адрес сайта / API Автомойки рядом",
        "en": "Washes Nearby site / API URL"
      },
      "default": "https://xn----7sb0aeimehj.xn--p1ai"
    },
    {
      "key": "poll_interval",
      "type": "number",
      "label": {
        "ru": "Интервал отправки (сек)",
        "en": "Send interval (sec)"
      },
      "default": 60,
      "min": 60,
      "max": 120
    },
    {
      "key": "news_limit",
      "type": "number",
      "label": {
        "ru": "Лимит новостей и акций",
        "en": "News & promotions limit"
      },
      "default": 5,
      "min": 1,
      "max": 50
    },
    {
      "key": "finance_timezone",
      "type": "string",
      "label": {
        "ru": "Часовой пояс кассы (IANA)",
        "en": "Finance timezone (IANA)"
      },
      "default": "Asia/Yekaterinburg"
    },
    {
      "key": "washes",
      "type": "string",
      "label": {
        "ru": "Параметры моек (JSON, заполняется UI)",
        "en": "Per-wash params (JSON, filled by UI)"
      },
      "default": ""
    }
  ]
}
